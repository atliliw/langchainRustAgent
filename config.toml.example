# ============================================================================
# LangChainRust Demo 配置文件示例
# ============================================================================
# 
# 使用说明：
# 1. 复制此文件为 config.toml
#    cp config.toml.example config.toml
# 2. 修改 api_key 和其他配置
# 3. 程序启动时会自动加载 config.toml

# ============================================================================
# Server 配置
# ============================================================================
[server]
host = "0.0.0.0"
port = 8080
upload_dir = "uploads"

# ============================================================================
# LLM API 配置（支持 OpenAI / 火山引擎）
# ============================================================================
# 
# 方式一：OpenAI
# [openai]
# api_key = "your-openai-api-key"
# base_url = "https://api.openai.com/v1"
# chat_model = "gpt-3.5-turbo"
# embedding_model = "text-embedding-3-small"
#
# 方式二：火山引擎（推荐）
[openai]
api_key = "your-volcengine-api-key"
base_url = "https://ark.cn-beijing.volces.com/api/v3"
chat_model = "your-endpoint-id"  # 火山引擎使用 endpoint_id
embedding_model = "your-endpoint-id"

# ============================================================================
# Embedding 配置（独立配置，可使用不同 API）
# ============================================================================
# 
# 方式一：OpenAI Embedding
# [embedding]
# api_key = "your-openai-api-key"
# base_url = "https://api.openai.com/v1"
# model = "text-embedding-3-small"
#
# 方式二：火山引擎 Embedding
[embedding]
api_key = "your-volcengine-api-key"
base_url = "https://ark.cn-beijing.volces.com/api/v3"
model = "your-embedding-endpoint-id"

# ============================================================================
# MongoDB BM25 文档存储配置
# ============================================================================
[mongodb]
uri = "mongodb://admin:password@localhost:27017"
database = "langchainrust_demo"
parent_collection = "bm25_parents"
chunk_collection = "bm25_chunks"

# ============================================================================
# SQLite 对话历史存储配置
# ============================================================================
[sqlite]
db_path = "conversations.db"

# ============================================================================
# Qdrant 向量数据库配置
# ============================================================================
[qdrant]
url = "http://localhost:6334"
collection_name = "demo_documents"
vector_size = 1536
distance = "Cosine"

# ============================================================================
# 文档处理配置
# ============================================================================
[document]
chunk_size = 500
chunk_overlap = 50
supported_types = ["txt", "pdf", "md", "json", "csv"]

# ============================================================================
# 搜索配置
# ============================================================================
[search]
default_top_k = 5
min_score = 0.5
test_sample_count = 10

# ============================================================================
# 日志配置
# ============================================================================
[logging]
level = "info"
file_output = false
log_file = "logs/demo.log"